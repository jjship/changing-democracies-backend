{
  "name": "cd_backend",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Jacek Skrzypek",
    "email": "devontheroof@gmail.com"
  },
  "scripts": {
    "start": "ts-node-dev --respawn ./src/main.ts",
    "start:prod": "node main.js",
    "build": "tsc",
    "test:integration": "NODE_ENV=test TEST_DATABASE=cd_backend_test mocha --config ./src/spec/.mocharc.spec.json",
    "typeorm": "typeorm-ts-node-commonjs -d src/db/dataSource.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "check-all": "npm run typecheck && npm run lint && npm run build && npm run test:integration",
    "migrate-to-neon": "ts-node ./scripts/migrate-to-neon.ts",
    "migrate-to-neon:prod": "node ./dist/scripts/migrate-to-neon.js",
    "migrate-narrative-translations": "ts-node ./scripts/migrate-narrative-translations.ts",
    "migrate-narrative-translations:prod": "node ./dist/scripts/migrate-narrative-translations.js",
    "import-tags": "ts-node ./scripts/import-tags.ts",
    "import-tags:prod": "node ./dist/scripts/import-tags.js",
    "import-fragment-tags": "ts-node ./scripts/import-fragment-tags.ts",
    "import-fragment-tags:prod": "node ./dist/scripts/import-fragment-tags.js",
    "import-tag-categories": "ts-node ./scripts/import-tag-categories.ts",
    "import-tag-categories:prod": "node ./dist/scripts/import-tag-categories.js",
    "install-migration-deps": "npm install --no-save dotenv ts-node @types/pg"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@sinclair/typebox": "^0.34.48",
    "async-cache-dedupe": "^2.2.0",
    "axios": "^1.13.6",
    "axios-retry": "^4.5.0",
    "csv-parse": "^5.6.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.0.0",
    "typeorm": "^0.3.28",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^4.0.0",
    "@types/uuid": "^10.0.0",
    "@types/uuid4": "^2.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "chai": "^5.3.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^56.0.1",
    "light-my-request": "^6.6.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "sinon": "^19.0.5",
    "sinon-chai": "^4.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "uuid4": "^2.0.3"
  },
  "engines": {
    "node": ">= 22.0.0",
    "npm": ">= 10.0.0"
  }
}
